# npm Configuration File

# Ensure consistent package installation
engine-strict=true

# Use exact versions for dependencies
save-exact=false

# Set registry
registry=https://registry.npmjs.org/

# Reduce log output
loglevel=warn

# Use package-lock.json
package-lock=true

# Automatic authentication for CI/CD
# auth-token will be set via environment variable in CI

# Optional: Set scope registry for private packages
# @scope:registry=https://npm.pkg.github.com/

# Progress bar (useful for CI)
progress=false

# Ensure reproducible installs
audit=true
